      "values": [
        {"key": "unipolar_10", "tag": "10V",  "formula": "scale * 10V",          "use": "volume, filter cutoff, any 0..+10V CV"},
        {"key": "bipolar_5",   "tag": "+-5V", "formula": "(scale-0.5) * 10V",    "use": "general bipolar modulation"},
        {"key": "voct_1oct",   "tag": "+-1V", "formula": "(scale-0.5) * 2V",     "use": "V/Oct pitch control, 1 octave range; knob at 0.5 = no shift"},
        {"key": "voct_2oct",   "tag": "+-2V", "formula": "(scale-0.5) * 4V",     "use": "V/Oct pitch control, 2 octave range"}
      ]
    }
