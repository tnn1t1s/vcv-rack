  "row_config": {
    "description": "Each of the 8 rows is independently configurable. When IN is patched, row is an attenuator (OUT = IN * scale). When IN is unpatched, row is a macro knob whose output voltage depends on mode.",
    "rows": 8,
    "per_row_labels": {
      "data_key": "labels",
      "type": "array<string>",
      "length": 8,
      "description": "Human-readable label displayed above each knob. Use to name the macro (e.g. TUNE, LEVEL, DECAY)."
    },
