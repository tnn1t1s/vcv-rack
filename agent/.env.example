# agent/.env.example -- copy to agent/.env and fill in real values
# Never commit agent/.env to version control.

# Required for scripter and patch_builder (OpenRouter API access)
OPENROUTER_API_KEY=sk-or-v1-...

# Required for narrator (Google Gemini TTS)
GOOGLE_API_KEY=AIza...

# Optional TTS configuration (narrator)
TTS_VOICE=Vindemiatrix
TTS_MODEL=gemini-2.5-pro-preview-tts

# Optional LiteLlm base URL override (if not using OpenRouter)
# OPENAI_API_BASE=https://openrouter.ai/api/v1
